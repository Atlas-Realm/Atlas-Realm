NODE_ENV=development
PORT=3000
HOST=127.0.0.1

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://atlas:atlas_secret@localhost:5432/atlas_realm

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_to_a_random_string_at_least_32_chars_long
JWT_REFRESH_SECRET=change_me_to_another_random_string_at_least_32_chars

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional: 3rd party game APIs
# STEAM_API_KEY=
# RAWG_API_KEY=
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=

# Optional: OAuth provider authorize URLs
# GOOGLE_OAUTH_URL=
# DISCORD_OAUTH_URL=
